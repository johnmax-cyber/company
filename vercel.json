{
  "rewrites": [
    {
      "source": "/config.js",
      "destination": "/api/config.js"
    },
    {
      "source": "/api/admin",
      "destination": "/api/admin.js"
    }
  ],
  "functions": {
    "/api/config.js": {
      "runtime": "nodejs18.x",
      "memory": 256,
      "maxDuration": 5
    },
    "/api/admin.js": {
      "runtime": "nodejs18.x",
      "memory": 512,
      "maxDuration": 10
    }
  },
  "env": {
    "NODE_ENV": "production"
  }
}